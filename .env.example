# 变量必须以 VITE_ 为前缀才能暴露给外部读取
NODE_ENV = 'development'
# 网站名称
VITE_APP_TITLE = 'Tools-Web'
# 简短描述
VITE_APP_DESC = '一个轻量的在线工具箱'
# base api
VITE_APP_BASE_API = '/v1'
# 服务端地址: https://xxx.xxx.com;
VITE_SERVE = ''
# 自定义启动host
VITE_HOST = '127.0.0.1'
# 第三方反馈互动地址
VITE_FEEDBACK_URL = ''
# 广告位开关
VITE_ADV_SHOW = 'false'
# 短链接解析云函数地址（阿里云 ESA 边缘函数）
# 部署 esa-functions/url-unshorten/index.js 后填写对应的函数 URL
# 不填写则页面禁用短链接解析功能
VITE_UNSHORTEN_API = ''